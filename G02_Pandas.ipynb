   },
   "source": [
    "## Importing and processing data\n",
    "\n",
    "The following code is adapted from Lecture 2. It imports the UN table with various country statistics, selects only data for year 2022 and only series giving the number of males and females in millions. You do not need to study this code in detail."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "zm5P3QCbo_mB"
   },
   "outputs": [],
   "source": [
    "# read the table\n",
    "url = 'https://fmfi-compbio.github.io/viz/data/Un_population.csv'\n",
    "column_names = ['Region ID', 'Region', 'Year',\n",
    "                'Series', 'Value', 'Footnotes', 'Source']\n",
    "un_table = pd.read_csv(url, encoding='latin-1', names=column_names, skiprows=2, thousands=\",\")\n",
    "# check that table size is as expected\n",
    "assert un_table.shape == (7873,7) \n",
    "\n",
    "# select only rows for countries, starting with Afghanistan\n",
    "# and only useful columns 1,...,4\n",
    "first_country = un_table.query('Region==\"Afghanistan\"').index[0]\n",
    "un_countries = un_table.iloc[first_country:, 1:5]\n",
    "\n",
    "# select only rows for year 2022\n",
    "# and only values giving the number of females and males in each country\n",
    "# in millions\n",
    "male_series = 'Population mid-year estimates for males (millions)'\n",
    "female_series = 'Population mid-year estimates for females (millions)'\n",
    "selected = (un_countries\n",
    "        .query('(Series==@male_series or Series==@female_series) and Year==2022')\n",
    "        .loc[:, ['Region', 'Series', 'Value']])"
   ]
  },
